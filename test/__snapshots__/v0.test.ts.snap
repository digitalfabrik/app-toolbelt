// Jest Snapshot v1, https://jestjs.io/docs/snapshot-testing

exports[`stability test build-config 1`] = `"Usage: whitelabel v0 build-config [options] [command] Options: -h, --help display help for command Commands: to-bash [options] <build-config-name> <platform> outputs the specified build config as key-value pairs which can be executed by bash to-json [options] <build-config-name> <platform> outputs the specified build config as JSON to-properties [options] <build-config-name> <platform> create and write a new properties file to the stdout write-xcconfig [options] <build_config_name> <platform> create and write a new buildConfig.tmp.xcconfig to the output directory write-plist [options] <build-config-name> <output-name> create and write a new plist file to the output directory help [command] display help for command"`;

exports[`stability test notify 1`] = `"Usage: whitelabel v0 notify [options] [command] Options: -h, --help display help for command Commands: mattermost [options] Send a message to a mattermost channel github-pr [options] <pr-number> <message> Send a review comment to a pull request on github help [command] display help for command"`;

exports[`stability test pr 1`] = `"Usage: whitelabel v0 pr [options] [command] Options: -h, --help display help for command Commands: open-pr [options] [files...] Commit the given files to a branch and open a pull request help [command] display help for command"`;

exports[`stability test release 1`] = `"Usage: whitelabel v0 release [options] [command] Options: -h, --help display help for command Commands: bump-to [options] <new-version-name> [new-version-code] Bump and tag the latest version create [options] <platform> <new-version-name> [new-version-code] creates a new release for the specified platform upload [options] Upload a release asset to github promote [options] Remove pre-release flag from the latest release help [command] display help for command"`;

exports[`stability test release-notes 1`] = `"Usage: whitelabel v0 release-notes [options] [command] Options: -h, --help display help for command Commands: parse-release-notes [options] parse, output the release notes as JSON string and write them to the specified file move-to [options] <new-version-name> move the release notes in 'unreleased' to a new subdirectory <new-version-name> prepare-metadata [options] <app-name> <store-name> <metadata-directory> prepare metadata for store help [command] display help for command"`;

exports[`stability test sentry 1`] = `"Usage: whitelabel v0 sentry [options] [command] Options: -h, --help display help for command Commands: create [options] <package-name> <version-name> <sourcemap-directory> create a new release on sentry. This file uses the configuration from ./.sentryclirc help [command] display help for command"`;

